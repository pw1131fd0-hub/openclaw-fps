{
  "name": "openclaw-fps",
  "version": "1.0.0",
  "description": "OpenClaw FPS - A browser-based first-person shooter game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite --port 3001 --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "fps",
    "game",
    "threejs",
    "webgl",
    "browser-game"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cannon-es": "^0.20.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.17.5",
    "vitest": "^1.6.1"
  }
}
